{
  "name": "lyra-ide",
  "version": "0.1.3",
  "description": "An open-source IDE with customizable AI agent integration",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "bash scripts/patch-electron-name.sh",
    "dev": "bash scripts/patch-electron-name.sh && npm run build:main && npm run build:preload && concurrently -k -n main,preload,renderer,electron -c blue,green,yellow,magenta \"vite build --config vite.main.config.ts --watch\" \"vite build --config vite.preload.config.ts --watch\" \"vite dev\" \"sleep 2 && LYRA_DEV=1 electron .\"",
    "start": "bash scripts/patch-electron-name.sh && npm run build && electron .",
    "build:renderer": "vite build",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build": "npm run build:renderer && npm run build:preload && npm run build:main",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:main": "vitest run --config vitest.config.ts",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ide",
    "editor",
    "ai",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.0"
  }
}
